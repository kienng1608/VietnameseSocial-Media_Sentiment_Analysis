# Environment Variables — copy file này thành .env và điền giá trị thực
# File này AN TOÀN để commit (không chứa secret thực)
# File .env KHÔNG được commit → đã có trong .gitignore

# ── API Config ────────────────────────────────────────────────────────────────
API_PORT=8000

# CORS — danh sách origin được phép, phân cách bằng dấu phẩy
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8080

# ── Gemini API (dùng cho labeling script) ────────────────────────────────────
# Lấy API key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Model paths ───────────────────────────────────────────────────────────────
# Đặt file svm_model.pkl vào thư mục models/ trong project
SVM_MODEL_PATH=/app/models/svm_model.pkl
VNCORENLP_DIR=/app/VnCoreNLP

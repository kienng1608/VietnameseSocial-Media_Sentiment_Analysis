models/*.pkl
models/*.bin
models/*.pt
models/*.safetensors

# ── Data files ────────────────────────────────────────────────────────────────
data/*.csv
data/*.json
data/*.parquet
!data/.gitkeep

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db


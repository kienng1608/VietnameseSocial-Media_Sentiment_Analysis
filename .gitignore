# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual env ───────────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

